# Required
TELEGRAM_TOKEN=
ALLOWED_GROUP_ID=
# Used by the bot container to connect to PostgreSQL in docker-compose
DATABASE_URL=postgresql://user:password@db:5432/dbname

# PostgreSQL container
POSTGRES_DB=dbname
POSTGRES_USER=user
POSTGRES_PASSWORD=password

# Mini-app
MINIAPP_URL=https://t.me/your_bot/app
# Internal port exposed by the bot container (compose maps host:container)
WEBAPP_PORT=8080

# Frontend note:
# React/TelegramUI mini-app static assets are built into the Docker image automatically.
# Use `make build-frontend` only for local static build/debug.

# Optional
# CONNECTION_MODE=polling
# WEBHOOK_URL=
# PORT=8443
# THREAD_ID=1
# TIMEZONE=Europe/Minsk
# LOG_LEVEL=INFO
